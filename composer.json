{
    "name": "example/loan-fee-calculator",
    "description": "CLI loan fee calculator with linear interpolation",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "php-di/php-di": "^7.0",
        "monolog/monolog": "^3.10",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.75"
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "autoload": {
        "psr-4": {
            "LoanFeeCalculator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LoanFeeCalculator\\Tests\\": "tests/"
        }
    }
}
